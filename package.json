{
  "name": "ui-frame",
  "version": "0.0.0",
  "main": "dist-electron/main.js",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "electron:dev": "concurrently --kill-others \"ng serve\" \"wait-on http://localhost:4200 && cross-env ELECTRON_ENV=development electron .\"",
    "electron:build": "npm run build && npm run build:electron && cross-env ELECTRON_ENV=production electron .",
    "electron:smoke": "npm run electron:build",
    "electron:dist": "npm run build && npm run build:electron && electron-builder",
    "test:shell": "ng test --include='src/app/shell/**/*.spec.ts' --watch=false",
    "test:smoke": "npm run build && npm run build:electron && node scripts/electron-smoke.mjs",
    "test:coverage": "ng test --watch=false --code-coverage",
    "test:coverage:ci": "ng test --watch=false --code-coverage --browsers=ChromeHeadless",
    "validate": "npm run test:coverage:ci && npm run test:smoke"
  },
  "private": true,
  "build": {
    "appId": "com.uiframe.app",
    "productName": "UI Frame",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/ui-frame/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "linux": {
      "target": "AppImage"
    },
    "mac": {
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    }
  },
  "dependencies": {
    "@ngrx/effects": "^19.2.1",
    "@ngrx/store": "^19.2.1",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^19.2.21",
    "@angular/animations": "^19.2.21",
    "@angular/cli": "^19.2.21",
    "@angular/common": "^19.2.21",
    "@angular/compiler": "^19.2.21",
    "@angular/compiler-cli": "^19.2.21",
    "@angular/core": "^19.2.21",
    "@angular/forms": "^19.2.21",
    "@angular/platform-browser": "^19.2.21",
    "@angular/platform-browser-dynamic": "^19.2.21",
    "@angular/router": "^19.2.21",
    "@types/jasmine": "~5.1.0",
    "@types/node": "^20.19.39",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^41.3.0",
    "electron-builder": "^24.13.3",
    "jasmine-core": "~5.1.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3",
    "wait-on": "^7.2.0",
    "zone.js": "^0.15.1"
  }
}
